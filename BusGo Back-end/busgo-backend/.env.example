# ─── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your-access-token-secret-minimum-32-chars
JWT_REFRESH_SECRET=your-refresh-token-secret-minimum-32-chars
JWT_RESET_SECRET=your-reset-token-secret-minimum-32-chars

# Access token TTL (seconds) — 15 minutes
JWT_ACCESS_EXPIRES_IN=900
# Refresh token TTL (seconds) — 7 days
JWT_REFRESH_EXPIRES_IN=604800
# Reset token TTL (seconds) — 5 minutes
JWT_RESET_EXPIRES_IN=300

# ─── bcrypt ────────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
# Auth routes: 10 requests per 15 minutes
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=10

# General routes: 100 requests per minute
RATE_LIMIT_GENERAL_WINDOW_MS=60000
RATE_LIMIT_GENERAL_MAX=100

# ─── QR Card ───────────────────────────────────────────────────────────────────
# QR token TTL in seconds — 30 seconds (matches Flutter app)
QR_TOKEN_EXPIRES_SECONDS=30

# ─── Reset PIN ─────────────────────────────────────────────────────────────────
# PIN TTL in minutes
RESET_PIN_EXPIRES_MINUTES=10

# ─── Supabase Storage ─────────────────────────────────────────────────────────
SUPABASE_STORAGE_AVATARS_BUCKET=avatars

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins (no spaces)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
